{
  "name": "reactjs-boilerplate",
  "version": "1.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "analyze": "next experimental-analyze",
    "build:e2e": "cp -n example.env.local .env.local && next build",
    "start": "next start",
    "lint": "eslint .",
    "prepare": "is-ci || husky",
    "release": "release-it",
    "app:config": "node ./.install-scripts/index.js",
    "generate:resource": "hygen generate resource",
    "postgenerate:resource": "npm run lint -- --fix",
    "lint:fix": "eslint . --fix",
    "generate:field": "hygen generate field",
    "postgenerate:field": "npm run lint -- --fix",
    "test:generators:static": "bash playwright-tests/generators/run-static.sh",
    "test:e2e:generators:crud": "bash playwright-tests/generators/run-crud.sh",
    "sb": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@faker-js/faker": "10.3.0",
    "@hookform/resolvers": "5.2.2",
    "@radix-ui/react-alert-dialog": "1.1.16",
    "@radix-ui/react-avatar": "1.1.12",
    "@radix-ui/react-checkbox": "1.3.4",
    "@radix-ui/react-dialog": "1.1.16",
    "@radix-ui/react-dropdown-menu": "2.1.17",
    "@radix-ui/react-label": "2.1.9",
    "@radix-ui/react-popover": "1.1.16",
    "@radix-ui/react-radio-group": "1.4.0",
    "@radix-ui/react-select": "2.3.0",
    "@radix-ui/react-separator": "1.1.9",
    "@radix-ui/react-slot": "1.2.5",
    "@radix-ui/react-switch": "1.3.0",
    "@radix-ui/react-tooltip": "1.2.9",
    "@react-oauth/google": "0.13.5",
    "@tanstack/react-query": "5.95.2",
    "@tanstack/react-query-devtools": "5.95.2",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "accept-language": "3.0.20",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "cmdk": "1.1.1",
    "date-fns": "3.6.0",
    "dotenv": "17.3.1",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.0",
    "i18next": "25.10.10",
    "i18next-browser-languagedetector": "8.2.1",
    "i18next-resources-to-backend": "1.2.1",
    "js-cookie": "3.0.5",
    "lucide-react": "1.18.0",
    "nanoid": "5.1.7",
    "next": "16.2.0",
    "next-themes": "0.4.6",
    "react": "19.2.4",
    "react-day-picker": "9.14.0",
    "react-dom": "19.2.4",
    "react-dropzone": "15.0.0",
    "react-hook-form": "7.72.0",
    "react-i18next": "16.6.2",
    "react-virtuoso": "4.18.3",
    "sonner": "2.0.7",
    "tailwind-merge": "3.6.0",
    "tw-animate-css": "1.4.0",
    "typescript": "5.9.3",
    "yup": "1.7.1"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "5.0.2",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@eslint/eslintrc": "3.3.5",
    "@eslint/js": "9.39.4",
    "@playwright/test": "1.60.0",
    "@release-it/conventional-changelog": "10.0.6",
    "@storybook/addon-docs": "10.5.3",
    "@storybook/addon-links": "10.5.3",
    "@storybook/addon-onboarding": "10.5.3",
    "@storybook/nextjs": "10.5.3",
    "@tailwindcss/postcss": "4.3.1",
    "@types/js-cookie": "3.0.6",
    "@typescript-eslint/eslint-plugin": "8.57.1",
    "@typescript-eslint/parser": "8.57.1",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "5.5.5",
    "eslint-plugin-storybook": "10.5.3",
    "husky": "9.1.7",
    "hygen": "6.2.11",
    "is-ci": "4.1.0",
    "prettier": "3.8.3",
    "release-it": "19.2.4",
    "storybook": "10.5.3",
    "tailwindcss": "4.3.1"
  },
  "release-it": {
    "$schema": "https://unpkg.com/release-it/schema/release-it.json",
    "git": {
      "commitMessage": "chore: release v${version}"
    },
    "github": {
      "release": true
    },
    "npm": {
      "publish": false
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "infile": "CHANGELOG.md",
        "preset": {
          "name": "conventionalcommits",
          "types": [
            {
              "type": "feat",
              "section": "Features"
            },
            {
              "type": "fix",
              "section": "Bug Fixes"
            },
            {
              "type": "perf",
              "section": "Performance Improvements"
            },
            {
              "type": "revert",
              "section": "Reverts"
            },
            {
              "type": "docs",
              "section": "Documentation"
            },
            {
              "type": "refactor",
              "section": "Code Refactoring"
            },
            {
              "type": "test",
              "section": "Tests"
            },
            {
              "type": "ci",
              "section": "Continuous Integration"
            }
          ]
        }
      }
    }
  },
  "overrides": {
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3"
  }
}
